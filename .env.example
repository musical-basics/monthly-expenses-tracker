# SimpleFIN Bridge access URL — get yours at https://beta-bridge.simplefin.org/
# Either set the access URL directly (after claiming a setup token) ...
SIMPLEFIN_ACCESS_URL=https://USERNAME:PASSWORD@beta-bridge.simplefin.org/simplefin

# ... or paste the one-time setup token here and the app will claim it on first sync,
# then persist the resulting access URL to data/.access_url. The setup token is
# single-use and burns after claim.
# SIMPLEFIN_SETUP_TOKEN=

# Bearer token required on every /api/* request (Commander sends this).
# Generate with: openssl rand -hex 32
AGENT_API_TOKEN=replace-me-with-a-long-random-string

# Where the SQLite DB lives. Defaults to ./data/subscriptions.db
# DB_PATH=./data/subscriptions.db

# How many days of history to pull on each sync. Defaults to 180.
# SYNC_LOOKBACK_DAYS=180
